# Application
VADS_APP_NAME=VADS API
VADS_ENVIRONMENT=local
VADS_DEBUG=false
VADS_API_PREFIX=/api
VADS_DATABASE_ECHO=false

# PostgreSQL
POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_DB=vads
POSTGRES_USER=vads
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_PORT=5432
VADS_DATABASE_URL=postgresql+psycopg://vads:replace-with-a-strong-password@postgres:5432/vads

# Redis and Celery
REDIS_IMAGE=redis:7-alpine
REDIS_PORT=6379
VADS_REDIS_URL=redis://redis:6379/0
VADS_CELERY_BROKER_URL=redis://redis:6379/0
VADS_CELERY_RESULT_BACKEND=redis://redis:6379/1
VADS_CELERY_TASK_ALWAYS_EAGER=false
VADS_DOCUMENT_PROCESSING_QUEUE=document-processing

# MinIO / S3
MINIO_IMAGE=minio/minio:latest
MINIO_ROOT_USER=vads-minio
MINIO_ROOT_PASSWORD=replace-with-a-strong-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
VADS_STORAGE_PROVIDER=MINIO
VADS_S3_ENDPOINT_URL=http://minio:9000
VADS_S3_ACCESS_KEY=vads-minio
VADS_S3_SECRET_KEY=replace-with-a-strong-password
VADS_S3_BUCKET_NAME=vads-documents
VADS_S3_REGION=us-east-1
VADS_S3_FORCE_PATH_STYLE=true

# HTTP and document policy
API_PORT=8000
MAX_UPLOAD_SIZE_MB=50
VADS_UPLOAD_SPOOL_MEMORY_MB=8
VADS_DELETE_OBJECT_ON_SOFT_DELETE=false
VADS_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Extraction, OCR and chunking
VADS_PDF_TEXT_MIN_CHARACTERS=20
VADS_PDF_TEXT_PAGE_RATIO=0.8
VADS_PDF_IMAGE_PAGE_RATIO=0.8
VADS_RENDER_DPI=150
VADS_OCR_PROVIDER=PADDLEOCR
VADS_OCR_REVIEW_CONFIDENCE_THRESHOLD=0.7
VADS_CHUNK_MIN_TOKENS=300
VADS_CHUNK_MAX_TOKENS=800
VADS_CHUNK_OVERLAP_TOKENS=75

# FPT AI Inference. Never commit a real key; keep it only in local/secret storage.
VADS_FPT_AI_ENABLED=false
VADS_FPT_AI_API_KEY=replace-with-fpt-ai-marketplace-key
VADS_FPT_AI_BASE_URL=https://mkp-api.fptcloud.com
VADS_FPT_AI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
VADS_FPT_AI_MODELS_PATH=/v1/models
VADS_FPT_AI_MODEL_MAP={}
VADS_FPT_AI_MAX_TOKENS=4096
VADS_FPT_AI_TEMPERATURE=0
VADS_FPT_AI_ALLOW_PRIVATE_DATA=false
